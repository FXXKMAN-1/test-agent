{
  "name": "agent-test",
  "version": "1.0.1",
  "description": "AgentTest - AI驱动的Web自动化测试桌面应用",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev:renderer": "vite build --watch",
    "build:main": "tsc -p tsconfig.electron.json --outDir dist-electron",
    "build": "npm run build:main && vite build",
    "dev": "npm run build:main && concurrently -k \"vite build --watch\" \"sleep 2 && electron dist-electron/main.js\"",
    "dist": "npm run build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "@langchain/core": "^1.1.49",
    "@langchain/langgraph": "^1.4.2",
    "@langchain/openai": "^1.4.7",
    "openai": "^4.94.0",
    "playwright": "^1.52.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "uuid": "^11.1.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "concurrently": "^9.1.0",
    "electron": "^42.4.0",
    "electron-builder": "^25.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0"
  },
  "build": {
    "appId": "com.agent-test.app",
    "productName": "AgentTest",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "dist/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/",
        "to": "resources/"
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}